# Build / release output
/dist/
/out/
/tmp/
# cross-compiled linux/amd64 binaries for the containerized e2e run (make e2e-docker)
.build/
# root-anchored: the compiled binary at the repo root, NOT the cmd/readout/ package
/readout
*.out
coverage.*

# Local tooling / editor / scratch
.DS_Store
.idea/
.vscode/
# root-anchored: locally downloaded tool binaries, not any nested dir of that name
/kind
/kubectl

#bmad
.agents/
_bmad/
_bmad-output/
.claude/

# Never publish: forge notes and parity artifacts
docs/forge
test-artifacts/

# Root asset-build toolchain (esbuild / Lightning CSS / biome / tsgo). The Go
# binary embeds the committed static/ artifacts and builds with NO Node, so
# node_modules is dev-only and never shipped.
/node_modules/

# Playwright e2e suite artifacts (baselines under __screenshots__/ ARE committed)
tests/e2e/node_modules/
tests/e2e/test-results/
tests/e2e/playwright-report/
tests/e2e/blob-report/
